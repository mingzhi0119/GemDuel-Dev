{
    "schemaVersion": 1,
    "boundaries": [
        {
            "id": "renderer-action-dispatch",
            "title": "Renderer action dispatch",
            "entrySurface": "networkDispatch / local reducer actions",
            "owner": "Frontend + Domain Logic",
            "validatorRefs": [
                "src/logic/actionValidation.ts",
                "src/logic/commandGate.ts",
                "src/logic/fsmPolicy.ts"
            ],
            "contractRefs": ["src/types/boundary.ts", "src/types/network.ts"],
            "reasonCodes": [
                "NON_PROTOCOL_ACTION",
                "NOT_GUEST_TURN",
                "AUTHORITY_REJECTED",
                "CHECKSUM_UNAVAILABLE"
            ],
            "runtimeSignals": ["HOST_INTENT_REJECTED", "HOST_CHECKSUM_DERIVATION_FAILED"],
            "testRefs": [
                "src/logic/__tests__/fsmPolicyMatrix.test.ts",
                "src/logic/__tests__/securityBoundaries.test.ts",
                "src/hooks/__tests__/useGameNetwork.test.tsx"
            ],
            "failClosedBehavior": "Illegal actions are rejected before reducer state mutation or network dispatch."
        },
        {
            "id": "network-message-parsing",
            "title": "Network message parsing",
            "entrySurface": "PeerJS data payload",
            "owner": "Networking",
            "validatorRefs": [
                "src/logic/networkMessageValidation.ts",
                "src/logic/networkProtocol.ts"
            ],
            "contractRefs": ["src/types/boundary.ts", "src/types/network.ts"],
            "reasonCodes": [
                "NETWORK_MESSAGE_INVALID_ENVELOPE",
                "NETWORK_MESSAGE_INVALID_BOOTSTRAP",
                "NETWORK_MESSAGE_INVALID_GUEST_INTENT",
                "NETWORK_MESSAGE_INVALID_HOST_DECISION",
                "NETWORK_MESSAGE_INVALID_SYNC_STATE",
                "NETWORK_MESSAGE_INVALID_RECOVERY_REQUEST"
            ],
            "runtimeSignals": ["NETWORK_MESSAGE_REJECTED"],
            "testRefs": [
                "src/logic/__tests__/propertyBoundaries.test.ts",
                "src/logic/__tests__/protocolRecoveryMatrix.test.ts",
                "src/logic/__tests__/networkMessageValidationBoundary.test.ts"
            ],
            "failClosedBehavior": "Malformed or unsupported messages are dropped before they reach multiplayer state transitions."
        },
        {
            "id": "guest-intent-authority-review",
            "title": "Guest intent authority review",
            "entrySurface": "HOST_DECISION / GUEST_INTENT",
            "owner": "Networking",
            "validatorRefs": [
                "src/logic/hostApproval.ts",
                "src/logic/networkRecovery.ts",
                "src/logic/networkChecksums.ts"
            ],
            "contractRefs": ["src/types/network.ts", "src/types/boundary.ts"],
            "reasonCodes": [
                "AUTHORITY_REJECTED",
                "CHECKSUM_UNAVAILABLE",
                "CHECKSUM_MISMATCH",
                "STALE_PACKET"
            ],
            "runtimeSignals": [
                "HOST_INTENT_REJECTED",
                "HOST_CHECKSUM_DERIVATION_FAILED",
                "HOST_DECISION_LATE",
                "HOST_DECISION_STALE",
                "HOST_DECISION_REJECTED",
                "HOST_DECISION_VERIFICATION_FAILED",
                "HOST_DECISION_VERIFIED"
            ],
            "testRefs": [
                "src/logic/__tests__/hostApproval.test.ts",
                "src/logic/__tests__/networkRecovery.test.ts",
                "src/hooks/__tests__/useGameNetwork.test.tsx"
            ],
            "failClosedBehavior": "Unauthorized, stale, or unverifiable guest intents are rejected or force authoritative recovery."
        },
        {
            "id": "replay-local-file-read",
            "title": "Replay local file read",
            "entrySurface": "Renderer file input",
            "owner": "Frontend + Domain Logic",
            "validatorRefs": ["src/app/io/safeReplayImport.ts"],
            "contractRefs": ["src/types/boundary.ts"],
            "reasonCodes": [
                "REPLAY_FILE_TOO_LARGE",
                "REPLAY_FILE_UNSUPPORTED_TYPE",
                "REPLAY_FILE_READ_FAILED",
                "REPLAY_FILE_INVALID_JSON"
            ],
            "runtimeSignals": ["REPLAY_BOUNDARY_REJECTED"],
            "testRefs": ["src/app/io/__tests__/safeReplayImport.test.ts"],
            "failClosedBehavior": "Oversized, unreadable, or non-JSON local files are rejected before replay schema parsing."
        },
        {
            "id": "replay-schema-deterministic-replay",
            "title": "Replay schema / deterministic replay",
            "entrySurface": "Replay JSON payload",
            "owner": "Domain Logic",
            "validatorRefs": [
                "src/app/io/safeReplayImport.ts",
                "src/logic/replayImport.ts",
                "src/logic/commandGate.ts"
            ],
            "contractRefs": ["src/types/boundary.ts", "src/types/domain.ts"],
            "reasonCodes": ["REPLAY_FILE_INVALID_SCHEMA"],
            "runtimeSignals": ["REPLAY_BOUNDARY_REJECTED"],
            "testRefs": [
                "src/app/io/__tests__/safeReplayImport.test.ts",
                "src/logic/__tests__/replayImport.test.ts"
            ],
            "failClosedBehavior": "Schema-invalid or nondeterministic replay histories fail closed and are never imported."
        },
        {
            "id": "ipc-bridge",
            "title": "IPC invoke/send",
            "entrySurface": "window.electron.* bridge",
            "owner": "Desktop Platform",
            "validatorRefs": [
                "electron/preloadContract.cjs",
                "electron/desktopGovernance.js",
                "scripts/check-electron-governance.mjs"
            ],
            "contractRefs": ["src/types/desktop.ts", "ELECTRON_IPC_ALLOWLIST.md"],
            "reasonCodes": ["IPC_REQUEST_REJECTED"],
            "runtimeSignals": ["IPC_REQUEST_REJECTED"],
            "testRefs": [
                "electron/__tests__/desktopGovernance.test.ts",
                "electron/__tests__/preloadContract.test.ts"
            ],
            "failClosedBehavior": "Unknown channels, unexpected payloads, and unauthorized senders are rejected in the main process."
        },
        {
            "id": "desktop-window-security",
            "title": "Desktop BrowserWindow security",
            "entrySurface": "Electron main window creation",
            "owner": "Desktop Platform",
            "validatorRefs": [
                "electron/desktopGovernance.js",
                "scripts/check-electron-governance.mjs"
            ],
            "contractRefs": [
                "electron/governance/desktop-policy.snapshot.json",
                "ELECTRON_IPC_ALLOWLIST.md"
            ],
            "reasonCodes": ["DESKTOP_POLICY_REJECTED"],
            "runtimeSignals": ["WINDOW_CREATED"],
            "testRefs": ["electron/__tests__/desktopGovernance.test.ts"],
            "failClosedBehavior": "BrowserWindow policy drift fails desktop governance checks before release or local desktop startup."
        },
        {
            "id": "runtime-relay-profile",
            "title": "Runtime env / ICE config",
            "entrySurface": "Renderer runtime bootstrap",
            "owner": "Desktop Platform + Networking",
            "validatorRefs": [
                "electron/runtimeConfig.js",
                "src/config/webrtc.ts",
                "src/app/runtime/useRuntimeAppConfig.ts"
            ],
            "contractRefs": [
                "src/types/runtime.ts",
                "src/types/boundary.ts",
                "DEPENDENCY_RUNTIME_GOVERNANCE.md"
            ],
            "reasonCodes": [
                "TURN_CREDENTIAL_BUNDLE_INVALID",
                "TURN_CREDENTIAL_BUNDLE_EXPIRED",
                "RUNTIME_ICE_CONFIG_INVALID"
            ],
            "runtimeSignals": [
                "ICE_PROFILE_LOADED",
                "ICE_PROFILE_FALLBACK",
                "APP_RUNTIME_CONFIG_LOADED",
                "APP_RUNTIME_CONFIG_FAILED"
            ],
            "testRefs": [
                "electron/__tests__/runtimeConfig.test.ts",
                "src/config/__tests__/webrtc.test.ts"
            ],
            "failClosedBehavior": "Invalid or expired relay profiles fall back to legacy runtime ICE config and then the STUN-only baseline."
        },
        {
            "id": "release-health-checklist",
            "title": "Release-health checklist",
            "entrySurface": "Release / CI gate",
            "owner": "Desktop Platform + Release Engineering",
            "validatorRefs": [
                "scripts/check-release-health.mjs",
                "scripts/releaseHealthChecklist.js",
                "scripts/releaseHealthOperations.js"
            ],
            "contractRefs": [
                "RELEASE_HEALTH_CHECKLIST.md",
                "OPERATIONS_SLO.md",
                "electron/governance/release-health-operations.snapshot.json"
            ],
            "reasonCodes": ["RELEASE_HEALTH_CHECK_FAILED"],
            "runtimeSignals": ["APP_READY", "APP_BOOT", "APP_RUNTIME_CONFIG_FAILED"],
            "testRefs": [
                "scripts/__tests__/releaseHealthChecklist.test.ts",
                "scripts/__tests__/releaseHealthOperations.test.ts"
            ],
            "failClosedBehavior": "Checklist or SLO drift blocks release-health gates before build and publish."
        },
        {
            "id": "dependency-governance",
            "title": "Dependency / package governance",
            "entrySurface": "CI + local scripts",
            "owner": "Release Engineering",
            "validatorRefs": [
                "scripts/check-dependency-governance.mjs",
                "scripts/check-license-governance.mjs",
                "scripts/check-sbom-governance.mjs",
                "scripts/check-secret-governance.mjs"
            ],
            "contractRefs": [
                "DEPENDENCY_RUNTIME_GOVERNANCE.md",
                "governance/dependency-license-allowlist.json",
                "governance/dependency-sbom.snapshot.json"
            ],
            "reasonCodes": [
                "DEPENDENCY_AUDIT_FAILED",
                "LICENSE_ALLOWLIST_FAILED",
                "SBOM_SNAPSHOT_DRIFT",
                "SECRET_ENV_DRIFT"
            ],
            "runtimeSignals": [
                "DEPENDENCY_GOVERNANCE_CHECK",
                "SECRET_ENV_DRIFT_GATE",
                "SBOM_GATE",
                "LICENSE_ALLOWLIST_GATE"
            ],
            "testRefs": [
                "scripts/__tests__/dependencyGovernance.test.ts",
                "electron/__tests__/runtimeConfig.test.ts"
            ],
            "failClosedBehavior": "Policy drift, production vulnerabilities, secret leaks, or SBOM drift block CI and release builds."
        }
    ]
}
