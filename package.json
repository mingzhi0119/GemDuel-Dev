{
    "name": "gem-duel",
    "private": true,
    "version": "5.2.11",
    "description": "A competitive strategy gem-collecting game built with React and Electron.",
    "author": "Mingzhi",
    "main": "electron/main.js",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "npm run boundaries:check && npm run deps:check && npm run licenses:check && npm run sbom:check && npm run secrets:check && npm run desktop:check && npm run build && npm run governance:artifacts && electron-builder",
        "boundaries:check": "node scripts/check-boundary-governance.mjs",
        "deps:check": "node scripts/check-dependency-governance.mjs",
        "governance:artifacts": "node scripts/export-governance-artifacts.mjs",
        "licenses:check": "node scripts/check-license-governance.mjs",
        "lint": "eslint .",
        "preview": "vite preview",
        "release:report": "node scripts/export-release-health-report.mjs",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:security": "vitest run electron/__tests__/desktopGovernance.test.ts electron/__tests__/runtimeHarness.test.ts src/app/io/__tests__/safeReplayImport.test.ts src/logic/__tests__/fsmPolicyMatrix.test.ts src/logic/__tests__/hostApproval.test.ts src/logic/__tests__/networkMessageValidationBoundary.test.ts src/logic/__tests__/propertyBoundaries.test.ts src/logic/__tests__/protocolRecoveryMatrix.test.ts src/logic/__tests__/securityBoundaries.test.ts src/hooks/__tests__/useConnectionHealth.test.tsx src/hooks/__tests__/useGameNetwork.test.tsx src/hooks/__tests__/useOnlineManager.test.tsx scripts/__tests__/boundaryGovernance.test.ts scripts/__tests__/runtimeDrillGovernance.test.ts",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "desktop:check": "node scripts/check-electron-governance.mjs && node scripts/check-runtime-drill-governance.mjs",
        "release:check": "node scripts/check-release-health.mjs",
        "runtime:drills:check": "node scripts/check-runtime-drill-governance.mjs",
        "sbom:check": "node scripts/check-sbom-governance.mjs",
        "secrets:check": "node scripts/check-secret-governance.mjs",
        "prepare": "husky"
    },
    "build": {
        "appId": "com.gemduel.app",
        "productName": "GemDuel",
        "directories": {
            "output": "dist_electron"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "package.json"
        ],
        "publish": {
            "provider": "github"
        },
        "win": {
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true
        }
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,css,md}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@types/canvas-confetti": "^1.9.0",
        "canvas-confetti": "^1.9.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron-is-dev": "^3.0.1",
        "electron-log": "^5.4.3",
        "electron-updater": "^6.6.2",
        "framer-motion": "^12.23.26",
        "immer": "^11.1.0",
        "lucide-react": "^0.479.0",
        "peer": "^1.0.2",
        "peerjs": "^1.5.5",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "use-immer": "^0.11.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.21.0",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.0.8",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.2.1",
        "electron": "^39.2.7",
        "electron-builder": "^26.0.12",
        "eslint": "^9.21.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-prettier": "^5.2.3",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "fast-check": "^4.7.0",
        "globals": "^16.0.0",
        "happy-dom": "^20.0.11",
        "husky": "^9.1.7",
        "lint-staged": "^15.4.3",
        "postcss": "^8.5.3",
        "prettier": "^3.5.3",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.0",
        "vite": "^6.2.1",
        "vitest": "^3.0.8",
        "wait-on": "^9.0.3"
    },
    "overrides": {
        "brace-expansion": "^5.0.5",
        "path-to-regexp": "0.1.13",
        "qs": "6.14.2",
        "yaml": "2.8.3",
        "anymatch": {
            "picomatch": "2.3.2"
        },
        "micromatch": {
            "picomatch": "2.3.2"
        },
        "readdirp": {
            "picomatch": "2.3.2"
        },
        "tinyglobby": {
            "picomatch": "4.0.4"
        }
    }
}
