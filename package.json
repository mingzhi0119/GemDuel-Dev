{
    "name": "gem-duel-workspace",
    "private": true,
    "version": "5.2.11",
    "description": "GemDuel monorepo controller for the desktop app, shared packages, and governance tooling.",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=24.12.0 <25",
        "pnpm": ">=10 <11"
    },
    "scripts": {
        "architecture:check": "turbo run architecture:check --filter=@gemduel/tools-scripts",
        "audit:gates": "turbo run audit:gates --filter=@gemduel/tools-scripts --",
        "bench": "turbo run bench --filter=@gemduel/tools-scripts --",
        "boundaries:check": "turbo run boundaries:check --filter=@gemduel/tools-scripts",
        "build": "turbo run build --filter=@gemduel/desktop...",
        "bundle:check": "turbo run bundle:check --filter=@gemduel/tools-scripts",
        "changelog:check": "turbo run changelog:check --filter=@gemduel/tools-scripts",
        "codeowners:check": "turbo run codeowners:check --filter=@gemduel/tools-scripts",
        "deps:check": "turbo run deps:check --filter=@gemduel/tools-scripts",
        "desktop:check": "turbo run desktop:check --filter=@gemduel/tools-scripts",
        "dev": "turbo run dev --filter=@gemduel/desktop",
        "electron:build": "pnpm run architecture:check && pnpm run boundaries:check && pnpm run deps:check && pnpm run licenses:check && pnpm run sbom:check && pnpm run secrets:check && pnpm run seal-exclusions:check && pnpm run desktop:check && pnpm run test:coverage && pnpm run build && pnpm run bundle:check && pnpm run bench && pnpm run audit:gates && pnpm run governance:report && pnpm run lifecycle:certify && pnpm run governance:artifacts && turbo run electron:build --filter=@gemduel/desktop",
        "electron:dev": "turbo run electron:dev --filter=@gemduel/desktop",
        "electron:lan:verify": "pnpm --dir tools/scripts run electron:lan:verify",
        "electron:open": "pnpm --dir apps/desktop run electron:open",
        "governance:artifacts": "turbo run governance:artifacts --filter=@gemduel/tools-scripts --",
        "governance:evidence:check": "turbo run governance:evidence:check --filter=@gemduel/tools-scripts --",
        "governance:report": "turbo run governance:report --filter=@gemduel/tools-scripts --",
        "licenses:check": "turbo run licenses:check --filter=@gemduel/tools-scripts",
        "lifecycle:certify": "turbo run lifecycle:certify --filter=@gemduel/tools-scripts --",
        "lint": "turbo run lint",
        "preview": "pnpm --dir apps/desktop preview",
        "release:check": "turbo run release:check --filter=@gemduel/tools-scripts",
        "release:provenance:check": "turbo run release:provenance:check --filter=@gemduel/tools-scripts --",
        "repo-settings:check": "turbo run repo-settings:check --filter=@gemduel/tools-scripts --",
        "runtime:drills:check": "turbo run runtime:drills:check --filter=@gemduel/tools-scripts",
        "sbom:check": "turbo run sbom:check --filter=@gemduel/tools-scripts",
        "seal-exclusions:check": "turbo run seal-exclusions:check --filter=@gemduel/tools-scripts",
        "secrets:check": "turbo run secrets:check --filter=@gemduel/tools-scripts",
        "test": "turbo run test --filter=@gemduel/desktop",
        "test:coverage": "turbo run test:coverage --filter=@gemduel/desktop",
        "test:security": "turbo run test:security --filter=@gemduel/desktop",
        "test:ui": "pnpm --dir apps/desktop test:ui",
        "typecheck": "turbo run typecheck",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,css,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@types/canvas-confetti": "^1.9.0",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.0.8",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.2.1",
        "electron": "^39.2.7",
        "electron-builder": "^26.0.12",
        "eslint": "^9.21.0",
        "fast-check": "^4.7.0",
        "happy-dom": "^20.0.11",
        "husky": "^9.1.7",
        "lint-staged": "^15.4.3",
        "postcss": "^8.5.3",
        "prettier": "^3.5.3",
        "tailwindcss": "^3.4.17",
        "turbo": "^2.5.5",
        "typescript": "^5.8.2",
        "vite": "^6.2.1",
        "vitest": "^3.0.8",
        "wait-on": "^9.0.3"
    },
    "pnpm": {
        "overrides": {
            "fs-extra": "10.1.0",
            "jsonfile": "6.2.1",
            "path-to-regexp": "0.1.13",
            "qs": "6.14.2",
            "yaml": "2.8.3",
            "anymatch>picomatch": "2.3.2",
            "micromatch>picomatch": "2.3.2",
            "readdirp>picomatch": "2.3.2",
            "tinyglobby>picomatch": "4.0.4"
        }
    }
}
