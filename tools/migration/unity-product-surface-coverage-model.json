{
    "schemaVersion": 1,
    "kind": "unity-product-surface-coverage-model",
    "name": "GemDuel Unity finite product-surface coverage model",
    "updatedAt": "2026-05-13",
    "principle": "Finite declared product surface coverage: declared entrypoints, UI command families, FSM phase edges, recovery/error classes, settings combination coverage, and deterministic model exploration.",
    "completionPolicy": {
        "completeRequires": [
            "Every required declared entrypoint has built Windows player fresh-launch evidence.",
            "Every required action family has legal and illegal built-player evidence unless explicitly marked legalOnly.",
            "Every required phase edge has hash-locked replay trace evidence from the built player.",
            "Every required recovery case proves visible error, unchanged state, unpolluted replay, and a later legal action.",
            "Every required settings combination proves save, exit or reload, restart or fresh launch, load, game start, and hash isolation.",
            "Every required visual/latency contract proves the Electron settings pixel contract, reserve Gold prompt affordance, reserved-card mini-stack sizing, and first/Replenish action latency budget.",
            "LAN, Online, and Visual Lab are implemented or user-approved exclusions are recorded.",
            "Release-runtime rules packaging no longer depends on a LocalDev TypeScript fixture driver or checkpoint replacement."
        ],
        "allowedFinalVerdicts": ["Complete", "Incomplete", "Blocked"],
        "boundedRepresentativeLabel": "bounded representative coverage"
    },
