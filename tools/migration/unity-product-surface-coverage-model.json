    "visualContracts": [
        {
            "id": "settings_menu_electron_pixel_parity",
            "label": "Settings menu matches Electron pixel contract",
            "required": true,
            "sourceOfTruth": "apps/desktop/src/app/chrome/AppChrome.tsx",
            "checks": [
                "panel width w-[248px] * lg:scale-[1.5] = 372px",
                "row height px-3 py-2.5 text-[13px] at scale 1.5 = 54px",
                "row font/height ratio 19.5/54 = 0.3611",
                "settings controls are visible clickable hit targets"
            ]
        },
        {
            "id": "reserve_gold_prompt",
            "label": "Reserve waiting phase highlights the selectable Gold gem",
            "required": true,
            "checks": [
                "RESERVE_WAITING_GEM exposes a ReserveGoldPrompt visible target",
                "prompt maps to the same board Gold target that the user must click"
            ]
        },
        {
            "id": "reserved_card_mini_stack",
            "label": "Reserved cards stay inside mini-stack bounds",
            "required": true,
            "checks": [
                "reserved visual target exists for the rendered card",
                "single-card reserved visual rect stays at or below 120x160px at 1920x1080"
            ]
        },
        {
            "id": "first_action_latency",
            "label": "First model-driven product action is within latency budget",
            "required": true,
            "budgetMs": 500
        },
        {
            "id": "replenish_latency",
            "label": "Replenish command is within latency budget when explored",
            "required": true,
            "budgetMs": 350
        }
    ],
