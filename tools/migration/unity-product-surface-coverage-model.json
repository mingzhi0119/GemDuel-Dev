    "phases": [
        "IDLE",
        "DRAFT_PHASE",
        "RESERVE_WAITING_GEM",
        "SELECT_CARD_COLOR",
        "BONUS_ACTION",
        "STEAL_ACTION",
        "PRIVILEGE_ACTION",
        "SELECT_ROYAL",
        "DISCARD_EXCESS_GEMS",
        "GAME_OVER",
        "modal",
        "review"
    ],
    "phaseEdges": [
        {
            "id": "IDLE->RESERVE_WAITING_GEM",
            "from": "IDLE",
            "to": "RESERVE_WAITING_GEM",
            "required": true,
            "families": ["reserve", "reserve_deck"]
        },
        {
            "id": "RESERVE_WAITING_GEM->IDLE",
            "from": "RESERVE_WAITING_GEM",
            "to": "IDLE",
            "required": true,
            "families": ["reserve", "reserve_deck", "cancel"]
        },
        {
            "id": "IDLE->SELECT_CARD_COLOR",
            "from": "IDLE",
            "to": "SELECT_CARD_COLOR",
            "required": true,
            "families": ["buy"]
        },
        {
            "id": "SELECT_CARD_COLOR->BONUS_ACTION",
            "from": "SELECT_CARD_COLOR",
            "to": "BONUS_ACTION",
            "required": false,
            "reachability": "unreachable-current-catalog",
            "exclusionReason": "Current Electron/shared product catalog has no bonus-gem Joker card that can transition directly from Joker color selection to BONUS_ACTION. Requiring this edge would require changing shared gameplay/catalog, which is outside Unity migration scope.",
            "families": ["joker_color", "buy"]
        },
        {
            "id": "SELECT_CARD_COLOR->IDLE",
            "from": "SELECT_CARD_COLOR",
            "to": "IDLE",
            "required": true,
            "families": ["joker_color", "buy"]
        },
        {
            "id": "IDLE->PRIVILEGE_ACTION",
            "from": "IDLE",
            "to": "PRIVILEGE_ACTION",
            "required": true,
            "families": ["privilege"]
        },
        {
            "id": "PRIVILEGE_ACTION->IDLE",
            "from": "PRIVILEGE_ACTION",
            "to": "IDLE",
            "required": true,
            "families": ["privilege", "cancel"]
        },
        {
            "id": "IDLE->SELECT_ROYAL",
            "from": "IDLE",
            "to": "SELECT_ROYAL",
            "required": true,
            "families": ["take_gems", "buy", "reserve"]
        },
        {
            "id": "SELECT_ROYAL->IDLE",
            "from": "SELECT_ROYAL",
            "to": "IDLE",
            "required": true,
            "families": ["royal"]
        },
        {
            "id": "SELECT_ROYAL->same-player-extra-turn",
            "from": "SELECT_ROYAL",
            "to": "same-player-extra-turn",
            "required": true,
            "families": ["royal"]
        },
        {
            "id": "DRAFT_PHASE->IDLE",
            "from": "DRAFT_PHASE",
            "to": "IDLE",
            "required": true,
            "families": ["draft_select", "draft_reroll"]
        },
        {
            "id": "IDLE->GAME_OVER",
            "from": "IDLE",
            "to": "GAME_OVER",
            "required": true,
            "families": ["buy", "royal", "replenish"]
        }
    ],
