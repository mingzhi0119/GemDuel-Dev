    "deterministicExploration": {
        "strategy": "phase-driven model exploration",
        "maxDefaultDepth": 120,
        "legalActionRequirement": "State hash must change and live replay event count must increase.",
        "illegalActionRequirement": "State hash must not change and live replay event count must not increase.",
        "coverageTargets": [
            "entrypoints",
            "actionFamilies",
            "phaseEdges",
            "recoveryCases",
            "settingsCombinations"
        ]
    },
    "releaseRuntimeRulesPackaging": {
        "required": true,
        "status": "blocked-until-packaged",
