{
    "name": "@gemduel/tools-scripts",
    "version": "5.2.11",
    "private": true,
    "type": "module",
    "scripts": {
        "ai:replays": "vite-node --script generate-ai-replays.mjs",
        "ai:replays:audit": "vite-node --script audit-ai-replays.mjs",
        "architecture:check": "node check-architecture-budgets.mjs",
        "audit:draft": "node draft-audit-report.mjs",
        "audit:gates": "node check-audit-gates.mjs",
        "bench": "vite-node --script run-lifecycle-benchmarks.mjs",
        "bundle:check": "node check-build-budget.mjs",
        "boundaries:check": "node check-boundary-governance.mjs",
        "changelog:check": "node check-changelog-governance.mjs",
        "codeowners:check": "node check-codeowners-governance.mjs",
        "deps:check": "node check-dependency-governance.mjs",
        "desktop:check": "node check-electron-governance.mjs && node check-runtime-drill-governance.mjs",
        "electron:lan:verify": "node verify-local-lan-duel.mjs",
        "governance:artifacts": "node export-governance-artifacts.mjs",
        "governance:dashboard": "node render-governance-dashboard.mjs",
        "governance:evidence:check": "node check-governance-evidence-health.mjs",
        "governance:report": "node generate-governance-report.mjs",
        "licenses:check": "node check-license-governance.mjs",
        "lifecycle:certify": "node check-lifecycle-certification.mjs",
        "lint": "eslint .",
        "release:check": "node check-release-health.mjs",
        "release:provenance:check": "node check-release-tag-provenance.mjs",
        "repo-settings:check": "node check-repo-settings-governance.mjs",
        "runtime:drills:check": "node check-runtime-drill-governance.mjs",
        "sbom:check": "node check-sbom-governance.mjs",
        "seal-exclusions:check": "node check-seal-exclusion-governance.mjs",
        "seal-exclusions:refresh-monthly": "node refresh-seal-exclusions-monthly-snapshot.mjs",
        "secrets:check": "node check-secret-governance.mjs",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@gemduel/config-vitest": "workspace:*",
        "@gemduel/shared": "workspace:*",
        "@gemduel/turn-service": "workspace:*"
    },
    "devDependencies": {
        "@gemduel/config-eslint": "workspace:*",
        "@gemduel/config-typescript": "workspace:*",
        "vite-node": "^3.2.4",
        "vitest": "^3.2.4"
    }
}
