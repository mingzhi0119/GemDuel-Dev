{
    "policyVersion": 2,
    "rendererTrust": {
        "dev": {
            "defaultUrl": "http://localhost:5173",
            "requiresExactProtocolHostPortPath": true,
            "unexpectedQueryRejected": true
        },
        "production": {
            "protocol": "file:",
            "entrypoint": "../dist/index.html",
            "arbitraryFileUrlRejected": true
        }
    },
    "mainWindow": {
        "autoHideMenuBar": true,
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800,
        "defaultAspectRatio": "16:10",
        "supportedAspectRatios": [
            {
                "ratio": "16:10",
                "width": 1280,
                "height": 800,
                "aspectRatio": 1.6
            },
            {
                "ratio": "16:9",
                "width": 1280,
                "height": 720,
                "aspectRatio": 1.7777777777777777
            }
        ],
        "webPreferences": {
            "nodeIntegration": false,
            "contextIsolation": true,
            "webSecurity": true,
            "allowRunningInsecureContent": false
        }
    },
    "bridgeApiKeys": [
        "cancelLanMatchmaking",
        "confirmLanPregameStart",
        "getAppVersion",
        "getLanMatchmakingState",
        "getReleaseHealthSnapshot",
        "getRuntimeIceServers",
        "getRuntimeRelayProfile",
        "onDownloadProgress",
        "onLanMatchmakingEvent",
        "onUpdateAvailable",
        "onUpdateDownloaded",
        "refreshRuntimeRelayProfile",
        "reportLanPeerReady",
        "reportReleaseHealth",
        "restartApp",
        "revokeRuntimeRelayProfile",
        "saveReplayToFolder",
        "selectLanPregameMode",
        "setDesktopAspectRatio",
        "startLanMatchmaking"
    ],
    "allowlistedChannels": [
        "cancel-lan-matchmaking",
        "confirm-lan-pregame-start",
        "download_progress",
        "get-app-version",
        "get-lan-matchmaking-state",
        "get-release-health-snapshot",
        "get-runtime-ice-servers",
        "get-runtime-relay-profile",
        "lan-matchmaking-event",
        "refresh-runtime-relay-profile",
        "report-lan-peer-ready",
        "report-release-health",
        "restart_app",
        "revoke-runtime-relay-profile",
        "save-replay-to-folder",
        "select-lan-pregame-mode",
        "set-desktop-aspect-ratio",
        "start-lan-matchmaking",
        "update_available",
        "update_downloaded"
    ]
}
